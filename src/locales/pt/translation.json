            "questions": {
                "generalProgress": {
                    "q": "Onde vejo o progresso geral?",
                    "a": "No Dashboard, o card \"Progresso Geral\" mostra um círculo com a porcentagem média de todos os Key Results."
                },
                "lateKRs": {
                    "q": "Como sei quais KRs estão atrasados?",
                    "a": "Na seção \"Key Results que Precisam de Atenção\" do Dashboard, os KRs são ordenados do menor para maior progresso."
                },
                "editKR": {
                    "q": "Como edito o valor de um KR?",
                    "a": "Você pode editar valores (Baseline, Real, Target) clicando diretamente na célula da tabela. Para editar título ou outras propriedades, clique no ícone de editar (<0></0>)."
                },
                "krColors": {
                    "q": "O que significam as cores dos KRs?",
                    "a": "Verde (70-100%): No caminho certo. Amarelo (40-69%): Atenção necessária. Vermelho (0-39%): Crítico, precisa de ação urgente."
                },
                "filterUnits": {
                    "q": "Como filtro por SXS ou Hiter?",
                    "a": "Use o dropdown \"Todas Unidades\" no topo direito das páginas Dashboard e Objetivos para filtrar por unidade de negócio."
                },
                "createAction": {
                    "q": "Como crio uma nova ação?",
                    "a": "Vá em Ações → Clique em \"+ Nova Ação\" → Preencha título, descrição, KR vinculado, prioridade e data limite → Clique em \"Criar Ação\"."
                },
                "changeActionStatus": {
                    "q": "Como mudo o status de uma ação?",
                    "a": "Passe o mouse sobre a ação → Clique nos 3 pontinhos (⋮) → Escolha o novo status: Em Progresso, Concluído ou Bloqueado."
                },
                "priorityColors": {
                    "q": "O que significam as cores de prioridade?",
                    "a": "Vermelho: Alta prioridade. Amarelo: Média prioridade. Cinza: Baixa prioridade."
                },
                "autoSave": {
                    "q": "Os dados são salvos automaticamente?",
                    "a": "Sim! Todas as alterações são salvas no banco de dados imediatamente e registradas na página de Auditoria."
                },
                "audit": {
                    "q": "Onde vejo as alterações feitas?",
                    "a": "No menu lateral, clique em \"Auditoria\" para ver todo o histórico de mudanças feitas no sistema."
                }
            }
        },
